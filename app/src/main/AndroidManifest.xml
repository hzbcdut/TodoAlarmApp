<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 通知：Android 13+ 运行时申请 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 全屏 Intent：Android 14 普通权限（用户可关） -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- 开机广播：用于恢复闹钟 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 响铃用前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- 阶段 7：申请加入电池优化白名单 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
        阶段 4 修复：setAlarmClock 在 Android 12+ 内部走 setExact 路径
        文档说"不需要"，实测某些 ROM/版本会抛 SecurityException
        用户可在系统设置 → 闹钟和提醒 → 关闭授权
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:name=".TodoAlarmApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TodoAlarmApp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TodoAlarmApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 阶段 3：锁屏通知的"完成" / "备注" Action 接收器 -->
        <receiver
            android:name=".notification.CompleteReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todoalarm.COMPLETE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".notification.ReplyReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todoalarm.REPLY" />
            </intent-filter>
        </receiver>

        <!-- 阶段 4：闹钟触发接收器（AlarmManager 唤醒） -->
        <receiver
            android:name=".alarm.AlarmFireReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todoalarm.ALARM_FIRE" />
            </intent-filter>
        </receiver>

        <!-- 阶段 4：响铃前台服务（MediaPlayer 循环） -->
        <service
            android:name=".alarm.AlarmRingService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- 阶段 5：锁屏全屏弹窗 Activity -->
        <activity
            android:name=".ui.screen.TodoAlertActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:taskAffinity=""
            android:theme="@style/Theme.TodoAlarmApp"
            android:turnScreenOn="true" />

        <!-- 阶段 6：开机 / 升级 / 时区变更 时重排闹钟 -->
        <receiver
            android:name=".alarm.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>

        <!-- 通知被滑动删除时触发 → 停响铃服务 -->
        <receiver
            android:name=".notification.DismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.todoalarm.DISMISS" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
